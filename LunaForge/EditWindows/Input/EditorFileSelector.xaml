<editWindows:EditWindow x:Class="LunaForge.EditWindows.Input.EditorFileSelector"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:editWindows="clr-namespace:LunaForge.EditWindows"
                        mc:Ignorable="d"
                        Title="Editor File Selector"
                        Height="150"
                        Width="480">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="10,10,10,0" Grid.Row="0">
            <TextBlock Text="Select a lfd or lua file:" Margin="0,0,0,5"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse..." Padding="16,4" Margin="5,0,0,0"
                        Click="Button_Click"/>
                <TextBox DockPanel.Dock="Left" x:Name="PathSelector"
                         VerticalContentAlignment="Center"/>
            </DockPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="10"
                    Grid.Row="1">
            <Button Content="OK" Width="75" Margin="0,0,5,0" Click="OnConfirmClick"/>
            <Button Content="Cancel" Width="75" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</editWindows:EditWindow>
