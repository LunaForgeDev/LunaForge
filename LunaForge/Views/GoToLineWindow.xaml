<Window x:Class="LunaForge.Views.GoToLineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LunaForge.Views"
        mc:Ignorable="d"
        Title="Go to line"
        Height="140"
        Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="12" Orientation="Vertical">
        <TextBlock Text="Lua line number:" Margin="0,0,0,6"/>
        <TextBox x:Name="LineInput" Margin="0,0,0,10"/>
        <Button Content="Go To" Click="OnGoClick" HorizontalAlignment="Right" Padding="16,4"/>
    </StackPanel>
</Window>
