<Window x:Class="LunaForge.Views.AddNodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LunaForge.Views"
        xmlns:vm="clr-namespace:LunaForge.ViewModels"
        xmlns:services="clr-namespace:LunaForge.Services"
        mc:Ignorable="d"
        Title="Add Node"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Height="400"
        Width="500">
    <Window.DataContext>
        <vm:AddNodeVM/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0"
                 Name="SearchBox"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,5"
                 Padding="4"
                 KeyDown="SearchBox_KeyDown"
                 VerticalContentAlignment="Center">
            <TextBox.Style>
                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Style.Resources>
                        <VisualBrush x:Key="HintBrush"
                                     TileMode="None"
                                     Opacity="0.4"
                                     Stretch="None"
                                     AlignmentX="Left">
                            <VisualBrush.Visual>
                                <TextBlock Text="Search nodes..."
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Style.Resources>
                    <Style.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background"
                                    Value="{StaticResource HintBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <ListBox Grid.Row="1"
                 Name="NodeListBox"
                 ItemsSource="{Binding FilteredItems}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 KeyDown="NodeListBox_KeyDown">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type services:ToolboxItem}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{Binding Icon}"
                               Width="16" Height="16"
                               Stretch="Fill"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CategoryName}"
                                       FontSize="10"
                                       Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Margin="0,5,0,0">
            <TextBlock Text="Tip: Press Enter to insert selected node"
                       Foreground="Gray"
                       VerticalAlignment="Center"
                       Margin="5"/>
            <Button Content="Add" Margin="2" Padding="5"
                    Command="{Binding OkCommand}"
                    IsDefault="True"/>
            <Button Content="Cancel" Margin="2" Padding="5"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
