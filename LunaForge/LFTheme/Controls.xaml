        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TreeView}">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource corner-main}">
                        <ScrollViewer Focusable="False" CanContentScroll="False" 
                                      Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TreeViewItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource text-800}"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TreeViewItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="19"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        
                        <!-- Vertical line going down to children (only visible when expanded and has items) -->
                        <Rectangle x:Name="VerLnDown" Grid.Column="0" Grid.Row="1"
                                   Width="1" HorizontalAlignment="Center" VerticalAlignment="Top"
                                   Height="10"
                                   Stroke="#888888" StrokeDashArray="1 2"
                                   SnapsToDevicePixels="True"
                                   Visibility="Collapsed"/>
                        
                        <!-- Expander toggle button -->
                        <ToggleButton x:Name="Expander" Grid.Column="0" Grid.Row="0"
                                      Style="{StaticResource TreeViewExpanderToggle}"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"/>
                        
                        <!-- Header content -->
                        <Border x:Name="Bd" Grid.Column="1" Grid.Row="0" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource corner-sm}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="PART_Header" ContentSource="Header" 
                                              HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- Children items container with left border as connector line -->
                        <Border x:Name="ChildrenBorder" Grid.Column="1" Grid.Row="1" 
                                Margin="0,0,0,0"
                                BorderThickness="1,0,0,0"
                                BorderBrush="#888888">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </Border.Style>
                            <ItemsPresenter x:Name="ItemsHost" Margin="7,0,0,0"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Show children and connector when expanded -->
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ChildrenBorder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        
                        <!-- Hide expander when no children -->
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            <Setter TargetName="ChildrenBorder" Property="BorderThickness" Value="0"/>
                        </Trigger>
                        
                        <!-- Selection styling -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource primary-200}"/>
                            <Setter Property="Foreground" Value="{DynamicResource text-900}"/>
                        </Trigger>
                        
                        <!-- Inactive selection -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsSelectionActive" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource background-200}"/>
                        </MultiTrigger>
                        
                        <!-- Hover styling -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource background-200}"/>
                        </MultiTrigger>
                        
                        <!-- Disabled styling -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource text-400}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style TargetType="ItemsPresenter">
                <Setter Property="Grid.IsSharedSizeScope" Value="True"/>
            </Style>
        </Style.Resources>
    </Style>
    <!--#endregion-->
