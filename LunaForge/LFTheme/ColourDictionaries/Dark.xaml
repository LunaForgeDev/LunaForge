<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Text Colors (inverted - light lavender for readability on dark) -->
    <Color x:Key="col-text-50">#FF0D0D19</Color>
    <Color x:Key="col-text-100">#FF1A1A32</Color>
    <Color x:Key="col-text-200">#FF2A2B52</Color>
    <Color x:Key="col-text-300">#FF3E4078</Color>
    <Color x:Key="col-text-400">#FF5456A0</Color>
    <Color x:Key="col-text-500">#FF7072B8</Color>
    <Color x:Key="col-text-600">#FF9C9ED4</Color>
    <Color x:Key="col-text-700">#FFB8BAE8</Color>
    <Color x:Key="col-text-800">#FFD4D6FC</Color>
    <Color x:Key="col-text-900">#FFEBEBF9</Color>
    <Color x:Key="col-text-950">#FFF5F5FC</Color>

    <SolidColorBrush x:Key="text-50" Color="{StaticResource col-text-50}"/>
    <SolidColorBrush x:Key="text-100" Color="{StaticResource col-text-100}"/>
    <SolidColorBrush x:Key="text-200" Color="{StaticResource col-text-200}"/>
    <SolidColorBrush x:Key="text-300" Color="{StaticResource col-text-300}"/>
